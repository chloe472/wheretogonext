# Server
PORT=

# Required for signing JWTs after Google login. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# MongoDB Atlas connection string 
MONGODB_URI=

#Google OAuth credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GOOGLE_PLACES_API_KEY=

GEMINI_API_KEY=
OPENAI_API_KEY=
# Optional:
GEMINI_MODEL=gemini-2.0-flash

# Open Exchange Rates (live FX conversion)
OPEN_EXCHANGE_RATES_APP_ID=
# Optional cache TTL for /api/currency/rates endpoint (default: 43200 = 12h)
OPEN_EXCHANGE_RATES_CACHE_SECONDS=43200